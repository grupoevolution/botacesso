generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./database.db"
}

// ── CONFIGURACAO GERAL ──────────────────────────────────────
model Config {
  id    Int    @id @default(autoincrement())
  chave String @unique
  valor String
}

model Admin {
  id    Int    @id @default(autoincrement())
  user  String @unique
  senha String
}

// ── BOTS DE ACESSO ──────────────────────────────────────────
model BotAcesso {
  id          Int      @id @default(autoincrement())
  tipo        String   // "pago" | "free"
  nome        String
  token       String   @unique
  grupoId     String   // ID do grupo/canal que gerencia
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now())
  leads       Lead[]
  funil       FunilAcesso?
  mensagensAgendadas MensagemAgendada[]
}

// ── FUNIL INICIAL (etapas por mensagem recebida) ─────────────
model FunilAcesso {
  id      Int          @id @default(autoincrement())
  botId   Int          @unique
  bot     BotAcesso    @relation(fields: [botId], references: [id], onDelete: Cascade)
  passos  PassoAcesso[]
}

model PassoAcesso {
  id        Int         @id @default(autoincrement())
  funilId   Int
  funil     FunilAcesso @relation(fields: [funilId], references: [id], onDelete: Cascade)
  ordem     Int
  texto     String?
  mediaUrl  String?
  mediaTipo String?
  delay     Int         @default(2)
}

// ── MENSAGENS AGENDADAS (dia X apos acesso) ──────────────────
model MensagemAgendada {
  id        Int       @id @default(autoincrement())
  botId     Int
  bot       BotAcesso @relation(fields: [botId], references: [id], onDelete: Cascade)
  nome      String    // ex: "rmkt_dia25", "remocao_dia30"
  diaEnvio  Int       // dias apos o acesso ser concedido
  horario   String    @default("10:00") // HH:MM horario Brasilia
  texto     String?
  mediaUrl  String?
  mediaTipo String?
  ativa     Boolean   @default(true)
  ordem     Int       @default(0)
}

// ── LEADS ────────────────────────────────────────────────────
model Lead {
  id            Int       @id @default(autoincrement())
  botId         Int
  bot           BotAcesso @relation(fields: [botId], references: [id])
  telegramId    String    // chat ID do lead
  username      String?
  nomeCompleto  String?
  plano         String    @default("mensal") // "mensal" | "trimestral" | "anual"
  status        String    @default("ativo")  // "ativo" | "expirado" | "removido" | "pendente"
  passoFunil    Int       @default(0)
  acessoConcedido Boolean @default(false)
  linkAcesso    String?   // link de convite gerado
  dataAcesso    DateTime? // quando o link foi enviado
  dataExpiracao DateTime? // calculada pelo plano
  renovadoEm   DateTime?
  criadoEm     DateTime  @default(now())
  mensagensEnviadas MensagemEnviada[]

  @@unique([botId, telegramId])
}

// ── REGISTRO DE MENSAGENS ENVIADAS ───────────────────────────
model MensagemEnviada {
  id                  Int              @id @default(autoincrement())
  leadId              Int
  lead                Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  mensagemAgendadaId  Int?
  tipo                String           // "funil" | "agendada" | "acesso" | "rmkt" | "remocao"
  enviadoEm           DateTime         @default(now())
}

// ── WEBHOOK PERFECTPAY ───────────────────────────────────────
model WebhookLog {
  id         Int      @id @default(autoincrement())
  payload    String
  status     String   // "processado" | "ignorado" | "erro"
  criadoEm  DateTime @default(now())
}
